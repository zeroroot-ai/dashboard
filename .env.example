# ============================================
# Gibson Dashboard Environment Configuration
# ============================================
# Copy this file to .env.local before running pnpm dev:
#   cp .env.example .env.local
#
# All variables marked REQUIRED must be set. The dashboard process will
# exit with a clear error naming the missing variable if any REQUIRED
# variable is absent — there are no silent localhost fallbacks.
#
# IMPORTANT: .env.local is gitignored and must NEVER be committed.
# All secrets must be sourced from Kubernetes Secrets or a vault.
#
# The dashboard NEVER opens a direct gRPC channel to the daemon.
# All daemon traffic goes through Envoy + ext-authz with SPIFFE mTLS.
# See scripts/check-no-direct-daemon-grpc.mjs for the build guard.

# ------------------------------------
# Gibson Platform Public URL (REQUIRED)
# ------------------------------------
# The Envoy ingress URL operators use to reach the platform API.
# Production: https://api.zeroroot.ai (or your domain).
# Kind dev:   http://localhost:30443 (NodePort Envoy).
GIBSON_PLATFORM_PUBLIC_URL=http://localhost:30443

# ------------------------------------
# Public app URL (REQUIRED)
# ------------------------------------
# Public base URL where the dashboard is reachable. Auth.js uses this
# for callback URLs, email links, and OG metadata. Production canonical
# is https://app.zeroroot.ai.
NEXTAUTH_URL=http://localhost:3000  # REQUIRED
AUTH_URL=http://localhost:3000      # REQUIRED
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Marketing host origin (deploy#630 S11 www/app split). When set AND distinct
# from AUTH_URL's host, middleware routes the marketing surface (/, /pricing,
# /docs, /contact-sales) to this host and the product surface to AUTH_URL's
# host. Leave unset for single-origin local dev (localhost serves both).
# Production canonical is https://www.zeroroot.ai.
# WWW_URL=https://www.zeroroot.ai

# Exact URI Zitadel has registered as a post_logout_redirect_uri for
# this OIDC client. RP-initiated logout sends this string verbatim
# (no path append, no trailing-slash synthesis); a mismatch makes
# Zitadel reject the logout with `invalid_request`. In kind dev the
# helm chart sets this to https://app.zeroroot.local:30443 and registers
# the same value on the Zitadel OIDC client; for local pnpm-dev set
# it to whatever origin you ran the dashboard at and ensure that URI
# is also registered on the gibson-dashboard OIDC client. REQUIRED.
POST_LOGOUT_REDIRECT_URI=http://localhost:3000

# ------------------------------------
# Auth.js (NextAuth v5)
# ------------------------------------
# Secret used to sign Auth.js session JWTs.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=<generate-with-openssl-rand-base64-32>
AUTH_SECRET=<generate-with-openssl-rand-base64-32>

# ------------------------------------
# Zitadel (upstream IdP)
# ------------------------------------
# Zitadel issues all user identities and sessions. Membership lives in
# Zitadel + OpenFGA, not in a local Postgres.
ZITADEL_ISSUER=
ZITADEL_CLIENT_ID=
ZITADEL_CLIENT_SECRET=

# ------------------------------------
# Neo4j (Knowledge Graph) (REQUIRED)
# ------------------------------------
NEO4J_URI=bolt://localhost:30687   # REQUIRED
NEO4J_USER=neo4j
NEO4J_PASSWORD=<your-neo4j-password>

# ------------------------------------
# Redis (sessions, rate limiting)
# ------------------------------------
REDIS_URL=redis://localhost:6379

# ------------------------------------
# SPIFFE (workload identity for daemon-fronting Envoy)
# ------------------------------------
# The SPIRE agent's JWKS endpoint for verifying JWT-SVIDs.
SPIFFE_JWKS_URL=http://127.0.0.1:9091/jwks
SPIFFE_TRUST_DOMAIN=zeroroot.ai
# Comma-separated SPIFFE IDs allowed to call /api/admin/* endpoints.
ALLOWED_ADMIN_SPIFFE_IDS=spiffe://zeroroot.ai/ns/gibson/sa/tenant-operator

# ------------------------------------
# Loki (log streaming — optional)
# ------------------------------------
LOKI_URL=http://gibson-loki:3100
LOKI_TENANT_ID=

# ------------------------------------
# Langfuse (trace viewer — optional)
# ------------------------------------
LANGFUSE_HOST=http://localhost:30300
LANGFUSE_ADMIN_PUBLIC_KEY=
LANGFUSE_ADMIN_SECRET_KEY=

# ------------------------------------
# Social sign-in providers (optional)
# ------------------------------------
# Enable each provider by setting BOTH _CLIENT_ID and _CLIENT_SECRET.
# If only one of the pair is set the dashboard will refuse to start (clear
# startup error naming the missing variable). Leave both empty to disable
# a provider entirely. Provider buttons render on the sign-in / sign-up
# pages only for providers with full credentials.

# GitHub: https://github.com/settings/developers
# Callback URL to whitelist: {NEXTAUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitLab: https://gitlab.com/-/profile/applications
# Callback URL to whitelist: {NEXTAUTH_URL}/api/auth/callback/gitlab
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# Google: https://console.cloud.google.com/apis/credentials
# Callback URL to whitelist: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft (Entra ID): https://portal.azure.com
# Callback URL to whitelist: {NEXTAUTH_URL}/api/auth/callback/microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID is REQUIRED when MICROSOFT_CLIENT_ID + _CLIENT_SECRET
# are set. There is NO default — you must make an explicit tenancy choice:
#   "common"        — personal + work accounts across any Azure AD tenant
#   "organizations" — any Azure AD tenant (no personal accounts)
#   "consumers"     — personal Microsoft accounts only
#   <GUID>          — a specific single Azure AD tenant
# The dashboard will refuse to start if this is left empty while the client
# credentials are set.
MICROSOFT_TENANT_ID=

# Auto-create a personal organisation for new users on first sign-in.
# Set to "false" to direct new social-sign-in users to the organisation
# selection / invitation-claim flow instead.
DASHBOARD_AUTO_CREATE_ORG=true

# ------------------------------------
# Stripe (billing — optional)
# ------------------------------------
# Use sk_test_... keys in development and staging.
# Use sk_live_... keys ONLY in production.
# The dashboard will throw at startup if NODE_ENV=production and a sk_test_
# key is detected, or vice versa. Keep live keys in AWS Secrets Manager
# (gibson/{env}/dashboard/stripe-secret-key) and mount via ESO.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Stripe Customer Portal configuration ID (bpc_...).
# Created by running: npx ts-node scripts/stripe-bootstrap.ts --test
STRIPE_PORTAL_CONFIGURATION_ID=bpc_REPLACE_ME

# Stripe Price IDs for each self-serve paid tier.
# Obtain from the Stripe Dashboard (Products → <plan> → Prices) or the
# stripe-bootstrap.ts script output. Use test-mode price IDs in dev/staging.
# enterprise-deploy is contact-sales and has no Stripe price.
STRIPE_PRICE_TEAM=price_REPLACE_ME
STRIPE_PRICE_ORG=price_REPLACE_ME
STRIPE_PRICE_ENTERPRISE=price_REPLACE_ME

# Enable paid-tier checkout flows. Set to "true" only after every STRIPE_PRICE_*
# env var above is configured. Defaults to false (paid tiers disabled).
DASHBOARD_BILLING_PAID_TIERS_ENABLED=false

# ------------------------------------
# Email provider
# ------------------------------------
# Options: log (default, prints to stdout), resend, smtp, ses
# In production on EKS: set to "ses" and configure IRSA for the dashboard pod.
DASHBOARD_EMAIL_PROVIDER=log

# SES From: address (required when DASHBOARD_EMAIL_PROVIDER=ses).
# Must be a verified SES identity in the same AWS account/region.
SES_FROM_ADDRESS=noreply@mail.zeroroot.ai

# ------------------------------------
# Public URL (for checkout success/cancel redirects)
# ------------------------------------
# Base URL of the dashboard visible to users. Used to construct
# Stripe checkout success_url and cancel_url. Should match NEXTAUTH_URL
# in production but may differ if the app is behind a CDN path prefix.
PUBLIC_URL=http://localhost:3000

# ------------------------------------
# Dashboard debug
# ------------------------------------
# Set to "1" to expose /api/debug/recent-errors and raise the Auth.js
# logger to debug. Never enable in environments that see real users.
DASHBOARD_DEBUG=0
