{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:3000/dashboard/teams",
        "http://localhost:3000/dashboard/permissions",
        "http://localhost:3000/dashboard/audit",
        "http://localhost:3000/dashboard/users"
      ],
      "numberOfRuns": 2,
      "settings": {
        "onlyCategories": ["accessibility", "performance", "best-practices"],
        "skipAudits": ["uses-http2"],
        "chromeFlags": "--no-sandbox --headless"
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:performance": ["warn", { "minScore": 0.85 }],
        "categories:best-practices": ["warn", { "minScore": 0.85 }],
        "color-contrast": ["error", { "minScore": 1 }],
        "aria-required-attr": ["error", { "minScore": 1 }],
        "aria-valid-attr": ["error", { "minScore": 1 }],
        "button-name": ["error", { "minScore": 1 }],
        "label": ["error", { "minScore": 1 }],
        "link-name": ["error", { "minScore": 1 }],
        "tabindex": ["warn", { "minScore": 1 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
