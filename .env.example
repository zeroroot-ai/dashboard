# ============================================
# Gibson Dashboard Environment Configuration
# ============================================
# Copy this file to .env.local and fill in values for your cluster:
#   cp .env.example .env.local
#
# IMPORTANT: .env.local is gitignored and must NEVER be committed.
# All secrets must be sourced from Kubernetes Secrets or a vault.
#
# The dashboard NEVER opens a direct gRPC channel to the daemon.
# All daemon traffic goes through Envoy + ext-authz with SPIFFE mTLS.
# See scripts/check-no-direct-daemon-grpc.mjs for the build guard.

# ------------------------------------
# Public app URL
# ------------------------------------
# Public base URL where the dashboard is reachable. Auth.js uses this
# for callback URLs, email links, and OG metadata. Production canonical
# is https://app.zero-day.ai.
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------------------------------------
# Auth.js (NextAuth v5)
# ------------------------------------
# Secret used to sign Auth.js session JWTs.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=<generate-with-openssl-rand-base64-32>
AUTH_SECRET=<generate-with-openssl-rand-base64-32>

# ------------------------------------
# Zitadel (upstream IdP)
# ------------------------------------
# Zitadel issues all user identities and sessions. Membership lives in
# Zitadel + OpenFGA, not in a local Postgres.
ZITADEL_ISSUER=
ZITADEL_CLIENT_ID=
ZITADEL_CLIENT_SECRET=

# ------------------------------------
# Neo4j (Knowledge Graph)
# ------------------------------------
NEO4J_URI=bolt://localhost:30687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<your-neo4j-password>

# ------------------------------------
# Redis (sessions, rate limiting)
# ------------------------------------
REDIS_URL=redis://localhost:6379

# ------------------------------------
# SPIFFE (workload identity for daemon-fronting Envoy)
# ------------------------------------
# The SPIRE agent's JWKS endpoint for verifying JWT-SVIDs.
SPIFFE_JWKS_URL=http://127.0.0.1:9091/jwks
SPIFFE_TRUST_DOMAIN=zero-day.ai
# Comma-separated SPIFFE IDs allowed to call /api/admin/* endpoints.
ALLOWED_ADMIN_SPIFFE_IDS=spiffe://zero-day.ai/ns/gibson/sa/tenant-operator

# ------------------------------------
# Loki (log streaming — optional)
# ------------------------------------
LOKI_URL=http://gibson-loki:3100
LOKI_TENANT_ID=

# ------------------------------------
# Langfuse (trace viewer — optional)
# ------------------------------------
LANGFUSE_HOST=http://localhost:30300
LANGFUSE_ADMIN_PUBLIC_KEY=
LANGFUSE_ADMIN_SECRET_KEY=

# ------------------------------------
# Social sign-in providers (optional)
# ------------------------------------
# Enable each provider by setting BOTH _CLIENT_ID and _CLIENT_SECRET.
# If only one of the pair is set the dashboard will refuse to start (clear
# startup error naming the missing variable). Leave both empty to disable
# a provider entirely. Provider buttons render on the sign-in / sign-up
# pages only for providers with full credentials.

# GitHub: https://github.com/settings/developers
# Callback URL to whitelist: {NEXTAUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitLab: https://gitlab.com/-/profile/applications
# Callback URL to whitelist: {NEXTAUTH_URL}/api/auth/callback/gitlab
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# Google: https://console.cloud.google.com/apis/credentials
# Callback URL to whitelist: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft (Entra ID): https://portal.azure.com
# Callback URL to whitelist: {NEXTAUTH_URL}/api/auth/callback/microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID is REQUIRED when MICROSOFT_CLIENT_ID + _CLIENT_SECRET
# are set. There is NO default — you must make an explicit tenancy choice:
#   "common"        — personal + work accounts across any Azure AD tenant
#   "organizations" — any Azure AD tenant (no personal accounts)
#   "consumers"     — personal Microsoft accounts only
#   <GUID>          — a specific single Azure AD tenant
# The dashboard will refuse to start if this is left empty while the client
# credentials are set.
MICROSOFT_TENANT_ID=

# Auto-create a personal organisation for new users on first sign-in.
# Set to "false" to direct new social-sign-in users to the organisation
# selection / invitation-claim flow instead.
DASHBOARD_AUTO_CREATE_ORG=true

# ------------------------------------
# Stripe (billing — optional)
# ------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ------------------------------------
# Dashboard debug
# ------------------------------------
# Set to "1" to expose /api/debug/recent-errors and raise the Auth.js
# logger to debug. Never enable in environments that see real users.
DASHBOARD_DEBUG=0
