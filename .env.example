# ============================================
# Gibson Dashboard Environment Configuration
# ============================================
# Copy this file to .env.local and fill in values for your cluster:
#   cp .env.example .env.local
#
# IMPORTANT: .env.local is gitignored and must NEVER be committed.
# All secrets must be sourced from Kubernetes Secrets or a vault.

# ------------------------------------
# Gibson Daemon (gRPC)
# ------------------------------------
# The daemon's gRPC endpoint. For Kind: http://localhost:30002
# For production: your internal service address.
GIBSON_DAEMON_URL=http://localhost:50002
GIBSON_API_URL=http://localhost:50002
GIBSON_PLATFORM_PUBLIC_URL=http://localhost:50002

# ------------------------------------
# Better Auth (identity backend)
# ------------------------------------
# Secret used to sign Better Auth session tokens. MUST match the value
# configured on the Gibson daemon (it verifies the same HMAC).
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=<generate-with-openssl-rand-base64-32>

# Public base URL where the dashboard is reachable. Better Auth uses this
# for callback URLs and email links.
BETTER_AUTH_URL=http://localhost:3000

# Audience claim used when verifying SPIFFE-authed daemon→dashboard admin
# calls. Must match the daemon's audience config.
BETTER_AUTH_ADMIN_AUDIENCE=gibson-dashboard

# ------------------------------------
# Postgres (Better Auth data)
# ------------------------------------
# Better Auth stores users/sessions/organizations here.
DATABASE_URL=postgres://gibson:<password>@localhost:5432/gibson_auth

# ------------------------------------
# Neo4j (Knowledge Graph)
# ------------------------------------
NEO4J_URI=bolt://localhost:30687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<your-neo4j-password>

# ------------------------------------
# Redis (sessions, rate limiting)
# ------------------------------------
REDIS_URL=redis://localhost:6379

# ------------------------------------
# SPIFFE (admin trust between daemon and dashboard)
# ------------------------------------
# The SPIRE agent's JWKS endpoint for verifying JWT-SVIDs.
SPIFFE_JWKS_URL=http://127.0.0.1:9091/jwks
SPIFFE_TRUST_DOMAIN=gibson.io
# Comma-separated SPIFFE IDs allowed to call /api/admin/* endpoints.
ALLOWED_ADMIN_SPIFFE_IDS=spiffe://gibson.io/ns/gibson/sa/tenant-operator

# ------------------------------------
# Loki (log streaming — optional)
# ------------------------------------
LOKI_URL=http://gibson-loki:3100
LOKI_TENANT_ID=

# ------------------------------------
# Langfuse (trace viewer — optional)
# ------------------------------------
LANGFUSE_HOST=http://localhost:30300
LANGFUSE_ADMIN_PUBLIC_KEY=
LANGFUSE_ADMIN_SECRET_KEY=

# ------------------------------------
# Stripe (billing — optional)
# ------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ------------------------------------
# Dashboard debug
# ------------------------------------
# Set to "1" to expose /api/debug/recent-errors and raise Better Auth's
# logger to debug. Never enable in environments that see real users.
DASHBOARD_DEBUG=0
