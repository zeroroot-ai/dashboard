// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`templates/billing-checkout-completed > subject and html match snapshot 1`] = `"Your Gibson trial has started — Squad plan"`;

exports[`templates/billing-checkout-completed > subject and html match snapshot 2`] = `"<!doctype html><html lang="en"><body style="margin:0;padding:24px;background:#0b0b0f;color:#e6e6ea;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;"><table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="max-width:560px;margin:0 auto;background:#15151c;border-radius:8px;padding:32px;"><tr><td><h1 style="margin:0 0 16px;font-size:20px;line-height:1.3;color:#ffffff;">Your Gibson trial has started</h1><p style="margin:0 0 16px;font-size:14px;line-height:1.5;color:#c5c5cc;">You're now on the <strong style="color:#ffffff;">Squad</strong> plan. Your payment method has been confirmed and you won't be charged until your trial ends on <strong style="color:#ffffff;">2026-05-24</strong>.</p><p style="margin:0 0 24px;font-size:14px;line-height:1.5;color:#c5c5cc;"><a href="https://app.zeroroot.ai/dashboard" style="display:inline-block;padding:10px 20px;background:#16a34a;color:#ffffff;text-decoration:none;border-radius:6px;font-weight:600;font-size:14px;">Go to Dashboard</a></p><p style="margin:0 0 16px;font-size:14px;line-height:1.5;color:#c5c5cc;">Need to update your payment method or review your subscription? <a href="https://billing.stripe.com/session/test_123" style="color:#c5c5cc;text-decoration:underline;">Visit the billing portal</a>.</p><p style="margin:0 0 16px;font-size:12px;line-height:1.5;color:#9999a3;">You can cancel at any time before 2026-05-24 with no charge. After the trial, your card will be billed automatically.</p><p style="margin:0;font-size:12px;color:#9999a3;">Questions? Contact <a href="mailto:support@zeroroot.ai" style="color:#c5c5cc;text-decoration:underline;">support@zeroroot.ai</a>.</p></td></tr></table></body></html>"`;

exports[`templates/billing-checkout-completed > subject and html match snapshot 3`] = `
"Hi,

Your Gibson Squad trial has started. Your payment method has been confirmed and you won't be charged until your trial ends on 2026-05-24.

Get started: https://app.zeroroot.ai/dashboard

Want to update your payment method or review your subscription? Visit the billing portal:
https://billing.stripe.com/session/test_123

Your trial runs until 2026-05-24. After that, your card will be charged automatically. You can cancel at any time before the trial ends with no charge.

Questions? Contact support@zeroroot.ai.

— The Gibson team"
`;

exports[`templates/billing-payment-failed > subject and html match snapshot 1`] = `"Action required: payment failed for your Gibson subscription"`;

exports[`templates/billing-payment-failed > subject and html match snapshot 2`] = `"<!doctype html><html lang="en"><body style="margin:0;padding:24px;background:#0b0b0f;color:#e6e6ea;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;"><table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="max-width:560px;margin:0 auto;background:#15151c;border-radius:8px;padding:32px;"><tr><td><div style="background:#7f1d1d;border-radius:6px;padding:12px 16px;margin:0 0 20px;"><p style="margin:0;font-size:14px;font-weight:600;color:#fca5a5;">Action required: payment failed</p></div><p style="margin:0 0 16px;font-size:14px;line-height:1.5;color:#c5c5cc;">A payment of <strong style="color:#ffffff;">49.00 USD</strong> for your Gibson subscription failed — insufficient_funds.</p><p style="margin:0 0 24px;font-size:14px;line-height:1.5;color:#c5c5cc;"><a href="https://billing.stripe.com/session/test_789" style="display:inline-block;padding:10px 20px;background:#dc2626;color:#ffffff;text-decoration:none;border-radius:6px;font-weight:600;font-size:14px;">Update payment method</a></p><p style="margin:0 0 16px;font-size:13px;color:#9999a3;">Stripe will retry the payment automatically on May 15, 2026.</p><p style="margin:0 0 16px;font-size:13px;line-height:1.5;color:#9999a3;border-top:1px solid #2a2a35;padding-top:16px;"><strong style="color:#fbbf24;">Important:</strong> if the payment is not resolved within 7 days, your subscription will be moved to read-only mode and paid features will be restricted.</p><p style="margin:0;font-size:12px;color:#9999a3;">Questions? Contact <a href="mailto:support@zeroroot.ai" style="color:#c5c5cc;text-decoration:underline;">support@zeroroot.ai</a>.</p></td></tr></table></body></html>"`;

exports[`templates/billing-payment-failed > subject and html match snapshot 3`] = `
"Hi,

A payment of 49.00 USD for your Gibson subscription failed (insufficient_funds).

To keep your subscription active, please update your payment method in the billing portal:
https://billing.stripe.com/session/test_789

Stripe will retry the payment automatically on May 15, 2026.

Important: if the payment is not resolved within 7 days, your subscription will be moved to read-only mode and paid features will be restricted.

Questions? Contact support@zeroroot.ai.

— The Gibson team"
`;

exports[`templates/billing-plan-changed > subject and html match snapshot 1`] = `"Your Gibson plan has been updated to Org"`;

exports[`templates/billing-plan-changed > subject and html match snapshot 2`] = `"<!doctype html><html lang="en"><body style="margin:0;padding:24px;background:#0b0b0f;color:#e6e6ea;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;"><table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="max-width:560px;margin:0 auto;background:#15151c;border-radius:8px;padding:32px;"><tr><td><h1 style="margin:0 0 16px;font-size:20px;line-height:1.3;color:#ffffff;">Plan updated to Org</h1><p style="margin:0 0 16px;font-size:14px;line-height:1.5;color:#c5c5cc;">Your Gibson plan has been updated from <strong style="color:#ffffff;">Squad</strong> to <strong style="color:#ffffff;">Org</strong>, effective May 10, 2026.</p><table role="presentation" cellpadding="0" cellspacing="0" border="0" style="background:#1e1e2a;border-radius:6px;padding:16px;margin:0 0 16px;width:100%;"><tr><td style="font-size:13px;color:#9999a3;padding-bottom:8px;">New plan</td><td style="font-size:13px;color:#ffffff;text-align:right;">Org</td></tr><tr><td style="font-size:13px;color:#9999a3;">New monthly amount</td><td style="font-size:13px;color:#ffffff;text-align:right;">$199/month</td></tr><tr><td style="font-size:13px;color:#9999a3;">Effective date</td><td style="font-size:13px;color:#ffffff;text-align:right;">May 10, 2026</td></tr></table><p style="margin:0 0 16px;font-size:13px;color:#9999a3;">A proration invoice has been generated for this change. <a href="https://invoice.stripe.com/i/test_proration" style="color:#c5c5cc;text-decoration:underline;">View invoice</a>.</p><p style="margin:0;font-size:12px;color:#9999a3;">Questions? Contact <a href="mailto:support@zeroroot.ai" style="color:#c5c5cc;text-decoration:underline;">support@zeroroot.ai</a>.</p></td></tr></table></body></html>"`;

exports[`templates/billing-plan-changed > subject and html match snapshot 3`] = `
"Hi,

Your Gibson plan has been updated from Squad to Org, effective May 10, 2026.

New monthly amount: $199/month

A proration invoice has been generated for the plan change: https://invoice.stripe.com/i/test_proration

Questions? Contact support@zeroroot.ai.

— The Gibson team"
`;

exports[`templates/billing-subscription-cancelled > subject and html match snapshot 1`] = `"Your Gibson subscription has been cancelled"`;

exports[`templates/billing-subscription-cancelled > subject and html match snapshot 2`] = `"<!doctype html><html lang="en"><body style="margin:0;padding:24px;background:#0b0b0f;color:#e6e6ea;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;"><table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="max-width:560px;margin:0 auto;background:#15151c;border-radius:8px;padding:32px;"><tr><td><h1 style="margin:0 0 16px;font-size:20px;line-height:1.3;color:#ffffff;">Subscription cancelled</h1><p style="margin:0 0 16px;font-size:14px;line-height:1.5;color:#c5c5cc;">Your Gibson subscription has been cancelled. You'll continue to have access to your account until <strong style="color:#ffffff;">May 31, 2026</strong>.</p><div style="background:#1e1e2a;border-radius:6px;padding:16px;margin:0 0 16px;"><p style="margin:0;font-size:13px;color:#9999a3;"><strong style="color:#fbbf24;">Data retention:</strong> Your workspace data will be retained for 7 days after cancellation (until May 31, 2026). After that, data may be permanently deleted.</p></div><p style="margin:0 0 16px;font-size:14px;line-height:1.5;color:#c5c5cc;">Want to reactivate? <a href="https://app.zeroroot.ai/pricing" style="color:#c5c5cc;text-decoration:underline;">View our plans</a> and start a new subscription at any time.</p><p style="margin:0;font-size:12px;color:#9999a3;">Questions? Contact <a href="mailto:support@zeroroot.ai" style="color:#c5c5cc;text-decoration:underline;">support@zeroroot.ai</a>.</p></td></tr></table></body></html>"`;

exports[`templates/billing-subscription-cancelled > subject and html match snapshot 3`] = `
"Hi,

Your Gibson subscription has been cancelled. You'll continue to have access to your account until May 31, 2026.

Data retention: your workspace data will be retained for 7 days after cancellation (until May 31, 2026). After that, data may be permanently deleted.

Want to reactivate your subscription? You can do so at any time from our pricing page:
https://app.zeroroot.ai/pricing

Questions? Contact support@zeroroot.ai.

— The Gibson team"
`;

exports[`templates/billing-trial-will-end > subject and html match snapshot 1`] = `"Your Gibson trial ends in 3 days"`;

exports[`templates/billing-trial-will-end > subject and html match snapshot 2`] = `"<!doctype html><html lang="en"><body style="margin:0;padding:24px;background:#0b0b0f;color:#e6e6ea;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;"><table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="max-width:560px;margin:0 auto;background:#15151c;border-radius:8px;padding:32px;"><tr><td><h1 style="margin:0 0 16px;font-size:20px;line-height:1.3;color:#ffffff;">Your trial ends in 3 days</h1><p style="margin:0 0 16px;font-size:14px;line-height:1.5;color:#c5c5cc;">Your <strong style="color:#ffffff;">Org</strong> trial is ending soon.</p><table role="presentation" cellpadding="0" cellspacing="0" border="0" style="background:#1e1e2a;border-radius:6px;padding:16px;margin:0 0 16px;width:100%;"><tr><td style="font-size:13px;color:#9999a3;padding-bottom:8px;">Current plan</td><td style="font-size:13px;color:#ffffff;text-align:right;">Org</td></tr><tr><td style="font-size:13px;color:#9999a3;">First charge</td><td style="font-size:13px;color:#ffffff;text-align:right;">$199/month on May 24, 2026</td></tr></table><p style="margin:0 0 16px;font-size:14px;line-height:1.5;color:#c5c5cc;">Update your payment method or cancel in the billing portal:</p><p style="margin:0 0 24px;font-size:14px;line-height:1.5;color:#c5c5cc;"><a href="https://billing.stripe.com/session/test_456" style="display:inline-block;padding:10px 20px;background:#16a34a;color:#ffffff;text-decoration:none;border-radius:6px;font-weight:600;font-size:14px;">Manage billing</a></p><p style="margin:0 0 16px;font-size:13px;line-height:1.5;color:#9999a3;">Want to explore other plans? <a href="https://app.zeroroot.ai/pricing" style="color:#c5c5cc;text-decoration:underline;">View pricing</a>.</p><p style="margin:0 0 16px;font-size:12px;color:#9999a3;">If you cancel before May 24, 2026, you won't be charged.</p><p style="margin:0;font-size:12px;color:#9999a3;">Questions? Contact <a href="mailto:support@zeroroot.ai" style="color:#c5c5cc;text-decoration:underline;">support@zeroroot.ai</a>.</p></td></tr></table></body></html>"`;

exports[`templates/billing-trial-will-end > subject and html match snapshot 3`] = `
"Hi,

Your Gibson Org trial ends in 3 days.

Current plan: Org
First charge: $199/month on May 24, 2026

To continue using Gibson, make sure your payment method is up to date. You can update your card or cancel in the billing portal:
https://billing.stripe.com/session/test_456

If you'd like to explore other plans, visit our pricing page:
https://app.zeroroot.ai/pricing

If you cancel before May 24, 2026, you won't be charged.

Questions? Contact support@zeroroot.ai.

— The Gibson team"
`;
